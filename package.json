{
  "name": "eidos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run dev --workspace=api",
    "dev:worker": "npm run dev --workspace=worker",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:worker\""
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
